{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Development Plan",
  "description": "Structured plan for implementing a development task",
  "type": "object",
  "required": ["taskId", "title", "phases", "subtasks"],
  "properties": {
    "taskId": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "technologyStack": {
      "type": "object",
      "properties": {
        "backend": {"type": "string"},
        "frontend": {"type": "string"},
        "database": {"type": "string"},
        "infrastructure": {"type": "string"}
      }
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Planning", "Design", "Implementation", "Testing", "Review", "Deployment", "Documentation"]
      }
    },
    "subtasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "phase", "status"],
        "properties": {
          "id": {"type": "integer"},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "phase": {"type": "string"},
          "status": {"type": "string", "enum": ["pending", "in_progress", "completed"]},
          "assignee": {"type": "string"},
          "estimatedHours": {"type": "number"},
          "completedAt": {"type": "string", "format": "date-time"},
          "dependencies": {"type": "array", "items": {"type": "integer"}},
          "notes": {"type": "string"}
        }
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {"type": "string"}
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": {"type": "string"},
          "probability": {"type": "string", "enum": ["low", "medium", "high"]},
          "impact": {"type": "string", "enum": ["low", "medium", "high"]},
          "mitigation": {"type": "string"}
        }
      }
    },
    "createdAt": {"type": "string", "format": "date-time"}
  }
}
